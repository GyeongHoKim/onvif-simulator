{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "version": "2",
  "name": "onvif-simulator",
  "outputfilename": "onvif-simulator-gui",
  "build:dir": "build",
  "assetdir": "frontend/dist",
  "reloaddirs": "internal",
  "frontend:dir": "frontend",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "wailsjsdir": "frontend/src/lib/wails",
  "viteServerTimeout": 10,
  "debounceMS": 100,
  "devServer": "localhost:34115",
  "bindings": {
    "ts_generation": {
      "output_type": "interfaces"
    }
  },
  "nsisType": "single",
  "info": {
    "companyName": "GyeongHoKim",
    "productName": "onvif-simulator",
    "productVersion": "0.1.0",
    "copyright": "Copyright © 2026 GyeongHoKim",
    "comments": "ONVIF device simulator with CLI, TUI, and GUI support"
  }
}
