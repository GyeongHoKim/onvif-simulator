# Number of virtual ONVIF devices to simulate
DEVICE_COUNT=2

# Per-device settings (index starts at 1, up to DEVICE_COUNT)
# RTSP URIs must be pre-existing and reachable at runtime.
# onvif-simulator forwards them as-is to ONVIF clients.

DEVICE_1_NAME=Camera-01
DEVICE_1_PORT=8080
DEVICE_1_RTSP_URI=rtsp://localhost:8554/live
DEVICE_1_MANUFACTURER=Acme
DEVICE_1_MODEL=VirtualCam-1000

DEVICE_2_NAME=Camera-02
DEVICE_2_PORT=8081
DEVICE_2_RTSP_URI=rtsp://localhost:8554/live2
DEVICE_2_MANUFACTURER=Acme
DEVICE_2_MODEL=VirtualCam-1000
